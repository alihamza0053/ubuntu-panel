# ServerHub panel — restricted sudo rules.
# Installed to /etc/sudoers.d/serverhub by deploy/install.sh.
#
# The panel runs as the unprivileged `serverhub` user and is only allowed to
# run these specific privileged commands without a password. Everything else
# still requires real root.

# --- Supervisor: control Streamlit dashboards + panel programs ---
serverhub ALL=(root) NOPASSWD: /usr/bin/supervisorctl *

# --- Nginx + Certbot: domain assignment and SSL (Phase 3) ---
serverhub ALL=(root) NOPASSWD: /usr/sbin/nginx -t
serverhub ALL=(root) NOPASSWD: /usr/bin/systemctl reload nginx
serverhub ALL=(root) NOPASSWD: /usr/bin/ln -sf /srv/nginx-configs/* /etc/nginx/sites-enabled/*
serverhub ALL=(root) NOPASSWD: /usr/bin/rm -f /etc/nginx/sites-enabled/*
serverhub ALL=(root) NOPASSWD: /usr/bin/certbot *

# --- APT package management (Phase 4) ---
serverhub ALL=(root) NOPASSWD: /usr/bin/apt-get update
serverhub ALL=(root) NOPASSWD: /usr/bin/apt-get -y upgrade
serverhub ALL=(root) NOPASSWD: /usr/bin/apt-get --simulate upgrade
serverhub ALL=(root) NOPASSWD: /usr/bin/apt-get -y install *
serverhub ALL=(root) NOPASSWD: /usr/bin/apt-get -y remove *

# --- MySQL management (Phase 4) ---
# Uses local socket root auth for create/drop/query/import/export.
# Bare forms (no args) are needed for backup restore (mysql reads SQL on stdin)
# and full dumps; the wildcard forms cover everything else.
serverhub ALL=(root) NOPASSWD: /usr/bin/mysql
serverhub ALL=(root) NOPASSWD: /usr/bin/mysql *
serverhub ALL=(root) NOPASSWD: /usr/bin/mysqldump
serverhub ALL=(root) NOPASSWD: /usr/bin/mysqldump *

# --- Apps section: vetted one-click installer (only known slugs) ---
serverhub ALL=(root) NOPASSWD: /srv/serverhub/bin/serverhub-app-install *

# --- Panel self-update (Settings → Updates → Update now) ---
serverhub ALL=(root) NOPASSWD: /srv/serverhub/bin/serverhub-self-update *

# --- System cleanup (Settings → System Cleanup) ---
serverhub ALL=(root) NOPASSWD: /srv/serverhub/bin/serverhub-cleanup *

# --- Docker engine + container apps (Apps section) ---
serverhub ALL=(root) NOPASSWD: /usr/bin/docker *
