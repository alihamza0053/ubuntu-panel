# ============================================================
# ServerHub backend configuration
# Copy to .env and edit values before first run.
# ============================================================

# Secret used to sign JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# Token lifetime in minutes (default: 12 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Path to the panel's internal SQLite database
DB_PATH=/srv/serverhub/db/serverhub.db

# Root folders managed by the panel
PROJECTS_ROOT=/srv/projects
WEBSITES_ROOT=/srv/websites
NGINX_CONFIGS_ROOT=/srv/nginx-configs

# Supervisor integration.
# SUPERVISOR_CONF_DIR must be writable by the panel user and included
# by supervisord (see deploy/README section "Supervisor include").
SUPERVISOR_CONF_DIR=/srv/serverhub/supervisor.d
SUPERVISOR_LOG_DIR=/var/log/supervisor
# Run supervisorctl through sudo (requires the sudoers rule in deploy/)
SUPERVISORCTL_USE_SUDO=true

# Streamlit dashboards get ports allocated starting from this number
DASHBOARD_PORT_START=8501

# Pipeline: re-run scripts that FAILED at the end of a run. Number of extra
# passes over the still-failing scripts (0 disables retrying).
PIPELINE_MAX_RETRIES=1

# Python interpreter used to run project scripts
PYTHON_BIN=python3
# Streamlit binary used in supervisor program commands
STREAMLIT_BIN=streamlit

# Port the FastAPI app listens on (behind nginx)
PANEL_PORT=8765

# Where the panel is installed
PANEL_ROOT=/srv/serverhub
# Source-code checkout the "Update now" button redeploys from
# (a git clone or uploaded bundle containing deploy/update.sh)
UPDATE_SRC=/opt/serverhub-src
